{
  "name": "@dream-xi/config",
  "version": "0.9.0-alpha",
  "description": "Dream XI AI — Platform config loader: reads .env, validates all settings, and exports a typed DreamXiConfig object.",
  "keywords": ["dream-xi", "config", "env", "validation", "typescript"],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@dream-xi/types": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "^5.6.0"
  }
}
