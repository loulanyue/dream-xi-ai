{
  "name": "@dream-xi/parser",
  "version": "0.1.0-alpha",
  "description": "Dream XI AI — LLM response parser supporting markdown JSON code blocks, dynamic key-value extractors, and markdown section structures. Zero dependencies.",
  "keywords": ["dream-xi", "parser", "llm-parser", "json-extractor", "typescript"],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "^5.6.0"
  }
}
