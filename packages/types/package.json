{
  "name": "@dream-xi/types",
  "version": "0.4.0-alpha",
  "description": "Dream XI AI — Core TypeScript type definitions for players, messages, memory, tactics, and platform config.",
  "keywords": ["dream-xi", "types", "typescript", "ai-agents"],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "^5.6.0"
  }
}
