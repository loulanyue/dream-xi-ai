{
  "name": "@dream-xi/server",
  "version": "1.0.0-alpha",
  "description": "Dream XI AI — HTTP server: Express app with middleware, health check, and API routing.",
  "keywords": ["dream-xi", "server", "express", "api", "typescript"],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "node --watch dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@dream-xi/config": "workspace:*",
    "@dream-xi/fair-play": "workspace:*",
    "@dream-xi/memory": "workspace:*",
    "@dream-xi/router": "workspace:*",
    "@dream-xi/tactic": "workspace:*",
    "@dream-xi/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.6.0"
  }
}
